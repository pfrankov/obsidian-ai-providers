{
    "name": "obsidian-ai-providers",
    "version": "1.9.2",
    "description": "A hub for setting AI providers (OpenAI-like, Ollama and more) in one place.",
    "main": "dist/main.js",
    "workspaces": [
        "packages/*"
    ],
    "scripts": {
        "dev": "node esbuild.config.mjs",
        "dev-test": "concurrently \"node esbuild.config.mjs\" \"npm run test:watch\"",
        "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
        "example:build": "cd packages/example-plugin && npm run build",
        "version": "node version-bump.mjs && npm run build && npm run format && git add manifest.json versions.json",
        "test": "vitest run --coverage",
        "test:watch": "vitest",
        "sdk:build": "cd packages/sdk && npm run build",
        "sdk:version": "cd packages/sdk && npm version",
        "sdk:publish": "cd packages/sdk && npm run build && npm publish",
        "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
        "format": "prettier --write \"src/**/*.{ts,js,json}\" \"packages/**/*.{ts,js,json}\" \"*.{ts,js,json}\"",
        "format:check": "prettier --check \"src/**/*.{ts,js,json}\" \"packages/**/*.{ts,js,json}\" \"*.{ts,js,json}\"",
        "typecheck": "tsc -noEmit -skipLibCheck && tsc -p packages/example-plugin/tsconfig.json -noEmit -skipLibCheck && tsc -p packages/sdk/tsconfig.json -noEmit -skipLibCheck",
        "check": "npm run lint && npm run test && npm run typecheck",
        "bench:retrieve": "tsx --tsconfig benchmarks/tsconfig.json benchmarks/retrieve-benchmark.ts",
        "bench:retrieve:simple": "MODE=simple tsx --tsconfig benchmarks/tsconfig.json benchmarks/retrieve-benchmark.ts"
    },
    "keywords": [
        "obsidian",
        "ollama",
        "ai",
        "plugin",
        "llm",
        "gpt",
        "openai",
        "openrouter",
        "gemini",
        "lmstudio",
        "providers",
        "sdk"
    ],
    "author": "Pavel Frankov",
    "license": "MIT",
    "dependencies": {
        "@anthropic-ai/sdk": "^0.82.0",
        "idb": "^8.0.0",
        "ollama": "^0.6.3",
        "openai": "^6.33.0"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@obsidian-ai-providers/sdk": "file:packages/sdk",
        "@testing-library/jest-dom": "^6.9.1",
        "@types/node": "^25.5.2",
        "@typescript-eslint/eslint-plugin": "^8.58.0",
        "@typescript-eslint/parser": "^8.58.0",
        "@vitest/coverage-v8": "^3.2.4",
        "builtin-modules": "^5.0.0",
        "concurrently": "^9.2.1",
        "electron": "^41.1.1",
        "esbuild": "^0.28.0",
        "eslint": "^10.2.0",
        "eslint-plugin-sonarjs": "^4.0.2",
        "jsdom": "^29.0.1",
        "obsidian": "^1.12.3",
        "prettier": "^3.8.1",
        "tslib": "^2.8.1",
        "tsx": "^4.21.0",
        "typescript": "^6.0.2",
        "vitest": "^3.2.4"
    }
}
